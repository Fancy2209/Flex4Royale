{
	"config": "flex",
	"compilerOptions": {
		"source-path": [
			"src",
			"projects/textLayout/bundles/en_US",
			"projects/framework/bundles/en_US",
			"projects/mx/bundles/en_US",
			"projects/spark/bundles/en_US"
		],
		"library-path": [
			"projects/textLayout/bin/textLayout_core.swc",
			"projects/framework/bin/framework.swc",
			"projects/mx/bin/mx.swc",
			"projects/spark/bin/spark.swc"

		],
		"output": "bin/project.swf",
		"targets": ["SWF"]
	},
	"mainClass": "project",
	"additionalOptions": [
		"-load-config=config/flex-config.xml"
	]
}

{
	"config": "flex",
	"compilerOptions": {
		"output": "bin/framework.swc",
		"accessible": true,
		"source-path": [
			"src",
			"bundles/en_US"
		],
		"swf-external-library-path": [
			"${royalelib}/libs/player/32.0/playerglobal.swc",
			"${royalelib}/libs/Reflection.swc"
		],
		"js-external-library-path": [
			"${royalelib}/libs/player/32.0/playerglobal.swc",
			"${royalelib}/libs/Reflection.swc"
		],
		"external-library-path": [
			"../textLayout/bin/textLayout_core.swc",
			"${royalelib}/libs/Core.swc",
			"${royalelib}/libs/Reflection.swc",
			"${royalelib}/libs/XML.swc"
		],
		"include-classes": [
			"FrameworkClasses"
		],
		"include-namespaces": [
			"library://ns.adobe.com/flex/mx"
		],
		"targets": ["SWF", "JS"],
		"define": [
			{"name": "COMPILE::SWF", "value": "AUTO"},
			{"name": "COMPILE::JS", "value": "AUTO"}
		],
		"keep-as3-metadata": ["Bindable","Managed","ChangeEvent","NonCommittingChangeEvent","Transient","Mixin"],
		"include-file": [
			{"file": "defaults.css", "path": "defaults.css"},
			{"file": "defaults-3.0.0.css", "path": "defaults-3.0.0.css"},
			//{"file": "assets/Assets.swf", "path": "Assets.swf"},
			{"file": "assets/CalendarIcon.png", "path": "assets/CalendarIcon.png"}
		]
	},
	"type": "lib",
	"additionalOptions": 
		[
			"-load-config=../../config/flex-config.xml", 
			"-load-config+=framework-config.xml",
			"--namespace=http://www.adobe.com/2006/mxml,manifest.xml",
			"--namespace+=library://ns.adobe.com/flex/mx,manifest.xml",
			"-resource-bundle-list=bundles.properties",
			"-include-resource-bundles+=SharedResources",
			"-include-resource-bundles+=collections",
			"-include-resource-bundles+=controls",
			"-include-resource-bundles+=core",
			"-include-resource-bundles+=effects",
			"-include-resource-bundles+=formatters",
			"-include-resource-bundles+=logging",
			"-include-resource-bundles+=modules",
			"-include-resource-bundles+=skins",
			"-include-resource-bundles+=states",
			"-include-resource-bundles+=styles",
			"-include-resource-bundles+=utils",
			"-include-resource-bundles+=validators",
		"-js-getter-prefix=get_",
		"-js-setter-prefix=set_"
		]
}